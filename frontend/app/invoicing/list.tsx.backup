  // Table View
  tableContainer: { backgroundColor: COLORS.white, borderRadius: 12, overflow: 'hidden', marginHorizontal: 8 },
  tableHeader: { flexDirection: 'row', backgroundColor: COLORS.lightGray, paddingVertical: 12, paddingHorizontal: 16 },
