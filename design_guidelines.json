{
  "project_name": "RetailPro Reports Redesign",
  "design_philosophy": {
    "identity": "E1: The Anti-AI Designer",
    "core_principles": [
      "Fusion over Imitation: Swiss Print Design meets Modern Fintech Dashboard",
      "Density with Breath: High information density (Bento) but with generous internal padding",
      "Function First: Color is for data status (Good/Bad/Neutral), not decoration",
      "Anti-Default: No generic shadows. Use crisp 1px borders and subtle background tints"
    ],
    "target_audience": "Tanzanian Retail Owners - Mobile & Desktop users",
    "mood": "Professional, Trustworthy, Organic Growth (Green), Crystal Clear"
  },
  "visual_language": {
    "colors": {
      "palette": {
        "primary": {
          "DEFAULT": "#1B4332",
          "dark": "#081C15",
          "light": "#2D6A4F",
          "soft": "#D8F3DC",
          "ultrasoft": "#F0FDF4"
        },
        "secondary": {
          "DEFAULT": "#D8F3DC",
          "foreground": "#1B4332"
        },
        "neutral": {
          "background": "#FFFFFF",
          "surface": "#F9FAFB",
          "border": "#E5E7EB",
          "text_primary": "#111827",
          "text_secondary": "#6B7280",
          "text_tertiary": "#9CA3AF"
        },
        "semantic": {
          "success": "#059669",
          "success_bg": "#ECFDF5",
          "warning": "#D97706",
          "warning_bg": "#FFFBEB",
          "danger": "#DC2626",
          "danger_bg": "#FEF2F2",
          "info": "#2563EB",
          "info_bg": "#EFF6FF"
        }
      },
      "usage_rules": [
        "NEVER use Primary (#1B4332) for large backgrounds. Use it for text, buttons, and active states.",
        "Backgrounds should be White (#FFFFFF) or Surface (#F9FAFB).",
        "Borders should be Neutral Border (#E5E7EB) or slightly darker on hover.",
        "Charts should use the Semantic palette for data points."
      ]
    },
    "typography": {
      "font_family": {
        "headings": "System (iOS/Android) or Manrope (if available)",
        "body": "System (iOS/Android) or Inter"
      },
      "scales": {
        "h1": { "fontSize": 24, "fontWeight": "800", "letterSpacing": -0.5, "lineHeight": 32 },
        "h2": { "fontSize": 20, "fontWeight": "700", "letterSpacing": -0.4, "lineHeight": 28 },
        "h3": { "fontSize": 18, "fontWeight": "600", "letterSpacing": -0.3, "lineHeight": 26 },
        "body_lg": { "fontSize": 16, "lineHeight": 24 },
        "body_md": { "fontSize": 14, "lineHeight": 20 },
        "body_sm": { "fontSize": 13, "lineHeight": 18 },
        "caption": { "fontSize": 11, "lineHeight": 14, "fontWeight": "600", "textTransform": "uppercase" }
      }
    },
    "spacing": {
      "grid_base": 4,
      "scale": {
        "xs": 4,
        "sm": 8,
        "md": 12,
        "lg": 16,
        "xl": 20,
        "2xl": 24,
        "3xl": 32,
        "4xl": 40
      }
    },
    "borders": {
      "radius": {
        "sm": 6,
        "md": 12,
        "lg": 16,
        "xl": 24,
        "full": 9999
      },
      "width": {
        "thin": 0.5,
        "default": 1,
        "focus": 2
      }
    },
    "shadows": {
      "none": { "shadowColor": "transparent" },
      "subtle": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 1 },
        "shadowOpacity": 0.05,
        "shadowRadius": 2,
        "elevation": 1
      },
      "card": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 2 },
        "shadowOpacity": 0.08,
        "shadowRadius": 8,
        "elevation": 3
      }
    }
  },
  "components": {
    "Container": {
      "style": {
        "flex": 1,
        "backgroundColor": "#F9FAFB"
      }
    },
    "Card": {
      "style": {
        "backgroundColor": "#FFFFFF",
        "borderRadius": 16,
        "borderWidth": 1,
        "borderColor": "#E5E7EB",
        "padding": 16,
        "marginBottom": 16
      },
      "notes": "Avoid heavy shadows. Use border definition."
    },
    "StatCard": {
      "style": {
        "width": "48%",
        "backgroundColor": "#FFFFFF",
        "borderRadius": 12,
        "padding": 16,
        "borderWidth": 1,
        "borderColor": "#E5E7EB"
      },
      "elements": {
        "value": { "fontSize": 24, "fontWeight": "700", "color": "#111827" },
        "label": { "fontSize": 13, "color": "#6B7280", "marginTop": 4 },
        "icon_container": { "padding": 8, "borderRadius": 8, "alignSelf": "flex-start", "marginBottom": 12 }
      }
    },
    "Button": {
      "primary": {
        "backgroundColor": "#1B4332",
        "borderRadius": 12,
        "paddingVertical": 12,
        "paddingHorizontal": 20,
        "alignItems": "center",
        "justifyContent": "center"
      },
      "secondary": {
        "backgroundColor": "#FFFFFF",
        "borderWidth": 1,
        "borderColor": "#E5E7EB",
        "borderRadius": 12,
        "paddingVertical": 12,
        "paddingHorizontal": 20
      },
      "text_primary": { "color": "#FFFFFF", "fontWeight": "600", "fontSize": 15 },
      "text_secondary": { "color": "#111827", "fontWeight": "600", "fontSize": 15 }
    },
    "TabSelector": {
      "container": {
        "flexDirection": "row",
        "backgroundColor": "#F3F4F6",
        "borderRadius": 12,
        "padding": 4,
        "marginBottom": 20
      },
      "tab": {
        "flex": 1,
        "paddingVertical": 8,
        "alignItems": "center",
        "borderRadius": 8
      },
      "tab_active": {
        "backgroundColor": "#FFFFFF",
        "shadowColor": "#000",
        "shadowOpacity": 0.05,
        "shadowRadius": 2,
        "elevation": 1
      },
      "text": { "fontSize": 13, "fontWeight": "600", "color": "#6B7280" },
      "text_active": { "color": "#111827" }
    }
  },
  "layout_strategy": {
    "structure": "Bento Grid (Mobile Adapted)",
    "sections": [
      {
        "id": "Header",
        "description": "Clean white header with Title and Export Action. NO GRADIENT BACKGROUNDS."
      },
      {
        "id": "PeriodFilter",
        "description": "Horizontal scrollable pills (Today, Week, Month). Active state: Dark Green text on Light Green bg."
      },
      {
        "id": "KeyMetrics",
        "description": "2x2 Grid of Stat Cards (Sales, Orders, Customers, Avg Value). Use Icons."
      },
      {
        "id": "MainChart",
        "description": "Large Card (Full Width). Tabs inside card to switch between Sales/Orders trend."
      },
      {
        "id": "SecondaryMetrics",
        "description": "Split Row: Payment Breakdown (Pie) + Top Products (List)."
      }
    ],
    "web_adaptations": [
      "On Desktop (width > 768px): Use a true Grid Layout.",
      "Sidebar Navigation (if not already present).",
      "Key Metrics in a single row (4 columns).",
      "Main Chart and Secondary Metrics side-by-side (2:1 ratio)."
    ]
  },
  "implementation_instructions": {
    "file_path": "/app/frontend/app/(tabs)/reports.tsx",
    "refactoring_steps": [
      "1. Extract `COLORS` to a new file `src/constants/theme.ts` (if possible) or define at top with new palette.",
      "2. Create sub-components within the file or separate files: `MetricCard`, `ChartSection`, `TransactionTable`.",
      "3. Replace `LinearGradient` hero with a clean `View` header.",
      "4. Update `PieChart` and `LineChart` props for a minimal look (hide axes, smooth lines, custom tooltips).",
      "5. Implement `ExportModal` as a bottom sheet (use `Modal` with `justifyContent: flex-end`)."
    ],
    "tech_stack_notes": "Project is Expo/React Native. Use `StyleSheet` and `react-native` primitives. Do NOT use HTML/Tailwind classes directly."
  },
  "chart_config": {
    "line_chart": {
      "thickness": 3,
      "color": "#1B4332",
      "startFillColor": "#1B4332",
      "endFillColor": "#FFFFFF",
      "startOpacity": 0.1,
      "endOpacity": 0.0,
      "curved": true,
      "hideRules": true,
      "yAxisThickness": 0,
      "xAxisThickness": 1,
      "xAxisColor": "#E5E7EB"
    },
    "pie_chart": {
      "donut": true,
      "radius": 70,
      "innerRadius": 50,
      "colors": ["#1B4332", "#2D6A4F", "#40916C", "#52B788"]
    }
  }
}
